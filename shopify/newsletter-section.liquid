<!-- ============================================================
     Travel & Draw — Shopify Liquid Section: Newsletter
     Annotated example showing the Impact theme newsletter form
     ============================================================ -->
{% comment %}
  Newsletter Section — Travel & Draw
  Theme: Impact v5

  Design tokens used:
  --footer-background: #F2F2F2
  --heading-font-family: 'Playfair', serif
  --text-font-family: 'Libre Franklin', sans-serif
  --button-background-primary: #1F2633
  --rounded-button: 3.75rem
  --rounded-input: 0.625rem
  --input-height: 2.625rem
{% endcomment %}

<style>
  .newsletter--{{ section.id }} {
    background: rgb(var(--footer-background)); /* #F2F2F2 */
    padding-block: var(--section-outer-spacing-block);
    text-align: center;
  }

  .newsletter--{{ section.id }} .newsletter__heading {
    font-family: var(--heading-font-family);
    font-weight: 400;
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .newsletter--{{ section.id }} .newsletter__subtitle {
    font-size: 1rem;
    color: rgb(var(--text-primary) / 0.7);
    margin-bottom: 1.5rem;
  }

  .newsletter--{{ section.id }} .newsletter__form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    max-width: 500px;
    margin-inline: auto;
  }

  .newsletter--{{ section.id }} .newsletter__input {
    flex: 1;
    height: var(--input-height);
    padding-inline: var(--input-padding-inline);
    border-radius: var(--rounded-input);
    border: 1px solid rgb(var(--text-primary) / 0.12);
    background: rgb(var(--background-primary));
    color: rgb(var(--text-primary));
    font-family: var(--text-font-family);
  }

  .newsletter--{{ section.id }} .newsletter__note {
    margin-top: 1rem;
    font-size: 0.75rem;
    color: rgb(var(--text-primary) / 0.4);
  }

  @media (max-width: 640px) {
    .newsletter--{{ section.id }} .newsletter__form {
      flex-direction: column;
    }
  }
</style>

<div class="newsletter--{{ section.id }}">
  <div class="container" style="max-width: 600px;">
    <div class="prose">

      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="newsletter__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          class="newsletter__input"
          placeholder="{{ section.settings.placeholder | default: 'E-mail' }}"
          required
          aria-label="{{ section.settings.placeholder | default: 'E-mail address' }}"
        >
        <button
          type="submit"
          class="button"
          style="
            background: rgb(var(--button-background-primary));
            color: rgb(var(--button-text-primary));
            border-radius: var(--rounded-button);
            font-family: var(--text-font-family);
            padding: 0.875rem 2.5rem;
            font-weight: 500;
            white-space: nowrap;
          "
        >
          {{ section.settings.button_text | default: 'Subscribe' }}
        </button>
      {%- endform -%}

      {%- if section.settings.note != blank -%}
        <p class="newsletter__note">{{ section.settings.note }}</p>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Newsletter",
  "class": "shopify-section--newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign up for exclusive insights"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Behind the scenes, new cities, and early access to new artwork."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Fine print note",
      "default": "No spam, no ads. Unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
