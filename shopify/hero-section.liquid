<!-- ============================================================
     Travel & Draw — Shopify Liquid Section: Hero
     Annotated example showing the Impact theme hero structure
     ============================================================ -->
{% comment %}
  Hero Section — Travel & Draw
  Theme: Impact v5
  Used on: Homepage, Landing pages, Collection pages

  Design tokens used:
  --heading-font-family: 'Playfair', serif
  --text-font-family: 'Libre Franklin', sans-serif
  --button-background-primary: #1F2633
  --button-text-primary: #FFFFFF
  --content-over-media-overlay: 0 0 0 / 0.3
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading | default: 'Travel & Draw'
  assign subheading = section.settings.subheading
  assign cta_text = section.settings.cta_text
  assign cta_url = section.settings.cta_url
  assign image = section.settings.image
  assign overlay_opacity = section.settings.overlay_opacity | default: 0.3
  assign text_color = section.settings.text_color | default: 'white'
  assign full_height = section.settings.full_height | default: true
-%}

<style>
  .hero--{{ section_id }} {
    --hero-overlay: 0 0 0 / {{ overlay_opacity }};
    {% if full_height %}
    min-height: 70vh;
    {% endif %}
  }
</style>

<image-with-text-overlay
  class="content-over-media content-over-media--{{ section_id }} hero--{{ section_id }}"
  reveal-on-scroll="true"
>
  {%- if image != blank -%}
    {{
      image
      | image_url: width: 2000
      | image_tag:
        loading: 'eager',
        sizes: '100vw',
        widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000',
        class: 'hero__image'
    }}
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
  {%- endif -%}

  {# Overlay #}
  <div class="content-over-media__overlay" style="background: rgb(var(--content-over-media-overlay, 0 0 0 / 0.0))"></div>

  {# Content #}
  <div class="content-over-media__content text-{{ text_color }} text-center">
    <div class="prose">
      {%- if heading != blank -%}
        <h1 class="h0" style="font-family: var(--heading-font-family); font-weight: 400;">
          {{ heading }}
        </h1>
      {%- endif -%}

      {%- if subheading != blank -%}
        <p class="hero__subtitle" style="font-family: var(--text-font-family); opacity: 0.8;">
          {{ subheading }}
        </p>
      {%- endif -%}

      {%- if cta_text != blank and cta_url != blank -%}
        <a
          href="{{ cta_url }}"
          class="button button--lg"
          style="
            background: rgb(var(--button-background-primary));
            color: rgb(var(--button-text-primary));
            border-radius: var(--rounded-button);
            font-family: var(--text-font-family);
          "
        >
          {{- cta_text -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</image-with-text-overlay>

{% schema %}
{
  "name": "Hero Section",
  "class": "shopify-section--hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Travel & Draw"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "white"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full height",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
